{
  "_version": "1.85.0",
  "sap.app": {
    "id": "com.fee.managefeed",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.25.0",
      "toolsId": "f9601d29-a7ca-4ce0-aa72-418391898f78"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v2/internal-services/",
        "odataVersion": "2.0",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "2.0"
        }
      },
       "jsonApiService": {
      "uri": "/odata/v4/json-api-services/",
      "type": "OData",
      "settings": {
        "odataVersion": "4.0"
      }
    },
       "mainService1": {
         "uri": "/odata/v4/businesspartner-services/",
    "type": "OData",
    "settings": {
      "odataVersion": "4.0"
    }
  }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.148.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
     "northwind": {
    "dataSource": "mainService1",
    "preload": true,
    "settings": {
      "operationMode": "Server",
      "autoExpandSelect": true,
      "earlyRequests": true
    }
  },
   "jsonApi": {
      "dataSource": "jsonApiService",
      "preload": true,
      "settings": {
      "operationMode": "Server",
      "autoExpandSelect": true,
      "earlyRequests": true
    }
    },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.fee.managefeed.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "com.fee.managefeed.view",
        "async": true,
        "viewPath": "com.fee.managefeed.view"
      },
      "routes": [
{
  "pattern" :"",
  "name": "RouteView1",
  "target": ["TargetView1"]
},
{
  "pattern" :"?query",
  "name": "RouteView2",
  "target": ["TargetView2"]
},
{
  "pattern" :"?query1",
  "name": "RouteView3",
  "target": ["TargetView3"]
}
      ],
      "targets": {
        "TargetView1": {
          "id": "View1",
          "name": "View1"
        },
         "TargetView2": {
          "id": "Home",
          "name": "Home"
        },
         "TargetView3": {
          "id": "Destination",
          "name": "Destination"
        }
      }
    },
    "rootView": {
      "viewName": "com.fee.managefeed.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
